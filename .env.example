# BrainyAct Mobile — Environment Variables
# Copy this file to .env and fill in your values

# API
EXPO_PUBLIC_API_URL=https://api.brainyact.com/v1

# Motion tracking provider: tensorflow_movenet | lightbuzz | arkit
EXPO_PUBLIC_MOTION_PROVIDER=tensorflow_movenet

# LightBuzz SDK license key (required if using lightbuzz provider)
EXPO_PUBLIC_LIGHTBUZZ_LICENSE=
